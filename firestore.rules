rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "sapemailb1@gmail.com";
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidBBQ(data) {
      return data.date is string && 
             data.location is string && data.location.size() > 0 &&
             data.address is string && data.address.size() > 0 &&
             data.pixKey is string && data.pixKey.size() > 0 &&
             data.totalCost is number && data.totalCost >= 0 &&
             (data.get('costs', []) is list) &&
             (data.get('receipts', []) is list) &&
             (data.get('staff', []) is list) &&
             (data.get('allowGuests', true) is bool);
    }

    function isValidParticipant(data) {
      return data.name is string && data.name.size() > 0 &&
             data.phone is string && data.phone.size() >= 8 &&
             (data.get('guestCount', 0) is number);
    }

    match /bbqs/{bbqId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidBBQ(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && isValidBBQ(request.resource.data));
      allow delete: if isAdmin();

      match /participants/{participantId} {
        allow read: if true;
        allow create: if isValidParticipant(request.resource.data);
        allow update: if true; 
        allow delete: if isAdmin();
      }
    }

    match /standardItems/{itemId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
